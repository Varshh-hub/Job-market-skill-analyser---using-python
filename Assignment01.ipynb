    {
      "cell_type": "code",
      "source": [
        "n = int(input(\"How many job postings do you want to add? \"))\n",
        "id = max(job_data[\"Job_ID\"]) + 1\n",
        "for i in range(n):\n",
        "    role = input(\"Enter role: \")\n",
        "    company = input(\"Enter company: \")\n",
        "    skills = input(\"Enter skills: \")\n",
        "\n",
        "    job_data[\"Job_ID\"].append(id)\n",
        "    job_data[\"Role\"].append(role)\n",
        "    job_data[\"Company\"].append(company)\n",
        "    job_data[\"Skills\"].append(skills)\n",
        "\n",
        "    id += 1\n",
        "print(job_data)"
      ],
      "metadata": {
        "id": "2BI2o4h4YetP"
      },
      "execution_count": null,
      "outputs": []
