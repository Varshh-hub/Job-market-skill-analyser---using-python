    {
      "cell_type": "code",
      "source": [
        "def find_jobs_by_skill(skill_query):\n",
        "    skill_query = skill_query.lower().strip()\n",
        "    result = []\n",
        "    if skill_query == \"\":\n",
        "        return result\n",
        "    elif skill_query:\n",
        "        for i in range(len(job_data[\"Job_ID\"])):\n",
        "            if skill_query in job_data[\"Skills\"][i].split():\n",
        "                result.append(\n",
        "                    (\n",
        "                        job_data[\"Job_ID\"][i],\n",
        "                        job_data[\"Role\"][i],\n",
        "                        job_data[\"Company\"][i]\n",
        "                    )\n",
        "                )\n",
        "        return result\n",
        "    else:\n",
        "        return result\n",
        "skill = input(\"Enter skill to search: \")\n",
        "print(find_jobs_by_skill(skill))"
      ],
