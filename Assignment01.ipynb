    {
      "cell_type": "code",
      "source": [
        "def clean_skills(skills):\n",
        "    skills = skills.lower()\n",
        "    skills = skills.replace(\",\", \" \")\n",
        "    skills = skills.replace(\".\", \" \")\n",
        "    skills = skills.replace(\"/\", \" \")\n",
        "    skills = \" \".join(skills.split())\n",
        "    return skills\n",
        "job_data[\"Skills\"] = [clean_skills(skill) for skill in job_data[\"Skills\"]]\n",
        "print(job_data[\"Skills\"])"
      ],
      "metadata": {
        "id": "-RSm0aQ0Yevm"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "all = []\n",
        "for skill in job_data[\"Skills\"]:\n",
        "    all.extend(skill.split())\n",
        "skill_count = {}\n",
        "for skill in all:\n",
        "    if skill in skill_count:\n",
        "        skill_count[skill] += 1\n",
        "    else:\n",
        "        skill_count[skill] = 1\n",
        "sorted_skills = sorted(skill_count.items(), key=lambda x: x[1], reverse=True)\n",
        "print(\"Top Skills\")\n",
        "for skill, count in sorted_skills[:5]:\n",
        "    print(skill, \":\", count)"
      ],
